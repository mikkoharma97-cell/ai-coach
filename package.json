{
  "name": "ai-coach",
  "version": "1.0.3",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:lan": "next dev -H 0.0.0.0 -p 3000",
    "dev:mobile": "node scripts/dev-mobile.mjs",
    "tunnel:ngrok": "ngrok http 3000",
    "tunnel:cloudflare": "cloudflared tunnel --url http://localhost:3000",
    "dev:webpack": "next dev --webpack",
    "build": "node scripts/write-build-info.mjs && next build",
    "start": "next start",
    "preview:clean": "node scripts/preview-clean.mjs",
    "preview:start": "NEXT_PUBLIC_PREVIEW_BUILD=1 npm run build && npm run start",
    "preview:full": "npm run preview:clean && npm run preview:start",
    "lint": "eslint",
    "verify:engine": "npx tsx scripts/verify-engine.ts",
    "audit:system": "npx tsx scripts/audit-system-v1.ts",
    "screenshots": "node scripts/capture-screenshots.mjs",
    "qa:routes": "node scripts/qa-final-routes.mjs",
    "cap:prepare": "node scripts/prepare-cap-web.mjs",
    "cap:sync": "npm run build && npm run cap:prepare && npx cap sync ios",
    "cap:sync:prod": "node scripts/cap-sync-prod.mjs",
    "cap:sync:dev": "node scripts/cap-sync-dev.mjs",
    "cap:open": "npx cap open ios",
    "cap:open:ios": "npx cap open ios",
    "native:ios": "npm run cap:sync && npm run cap:open:ios",
    "testflight:prep": "npm run cap:sync:prod && npm run cap:open:ios"
  },
  "dependencies": {
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.2.0",
    "@capacitor/core": "^7.2.0",
    "@capacitor/ios": "^7.6.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "playwright": "^1.50.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
