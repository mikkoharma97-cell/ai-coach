# Julkinen sivusto-URL (metadata, OG). Vercelissä valinnainen — `VERCEL_URL` käytetään automaattisesti.
# Esimerkki: https://oma-app.vercel.app
# NEXT_PUBLIC_SITE_URL=

# Valinnainen: näkyvä versio / aika UI:ssa ja cache-testeissä (Vercel Project → Environment Variables)
# NEXT_PUBLIC_APP_VERSION=1.0.3
# NEXT_PUBLIC_BUILD_TIME=2026-03-31T12:00:00.000Z

# Vain jos kutsut POST /api/training-intelligence/refresh cronista (Authorization: Bearer …)
# CRON_SECRET=

# FLOW: console.log("FLOW:", …) myös production-buildissa (debug)
# NEXT_PUBLIC_COACH_FLOW_DEBUG=0

# Coach: näytä hillitty Review-debug-paneeli ilman ?review=1 (staging)
# NEXT_PUBLIC_REVIEW_PANEL=0

# Valinnaiset: demo / preview / trial-mock (katso koodi)
# NEXT_PUBLIC_DEMO_MODE=0
# NEXT_PUBLIC_PREVIEW_BUILD=0
# NEXT_PUBLIC_COACH_MOCK_TRIAL_DAYS=
